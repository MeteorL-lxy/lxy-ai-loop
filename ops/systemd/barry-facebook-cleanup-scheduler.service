[Unit]
Description=Barry Facebook nightly cleanup scheduler
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/barry-facebook-loop
ExecStart=/opt/barry-facebook-loop/scripts/run-server-daily-cleanup.sh
Restart=always
RestartSec=30

[Install]
WantedBy=multi-user.target
